# Dev-only image: the Node toolchain lives here so nothing but Docker is
# needed on the host. Source is bind-mounted and deps install at runtime into
# a named volume, so this image builds fine before the app is even scaffolded.
FROM node:22-bookworm-slim

WORKDIR /app

# Vite dev server
EXPOSE 5173

# Default: run the dev server bound to all interfaces so the host can reach it
# through the published port. One-off commands override this via
# `docker compose run --rm web <cmd>`.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
